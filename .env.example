# Local Postgres (see compose.yaml defaults)
DATABASE_URL=postgresql://guge:guge@127.0.0.1:5432/guge

# Docker Compose（compose.vps.yaml）生产数据库密码（必须与 DATABASE_URL 中的密码一致）
POSTGRES_PASSWORD=guge

# Admin (single operator) — 生成哈希：pnpm --filter web run hash-admin-password -- '你的明文口令'
ADMIN_JWT_SECRET=change-me-to-a-long-random-string
# 本地 Next 直读 .env：用 bcrypt 原样（单 $）。若该文件仅给 Docker Compose 作 env_file：须把哈希里每个 $ 写成 $$，否则容器内变量被展开，登录永远失败。
ADMIN_PASSWORD_HASH=$2a$10$replace_with_bcrypt_hash

# 前台访客 JWT 会话（与 ADMIN_JWT_SECRET 分离；用于 /account 登录 Cookie guge_user）
USER_JWT_SECRET=change-me-to-another-long-random-string

# Newsletter：默认 console 干跑（终端打印确认/退订链接）；生产可改为 smtp（需在代码中接入 nodemailer）
EMAIL_TRANSPORT=console
# 发件人地址（部分供商要求与域一致）；console 模式可占位
NEWSLETTER_FROM=newsletter@example.com
# 未来真 SMTP 示例（本切片未实现）：SMTP_HOST= SMTP_PORT=587 SMTP_USER= SMTP_PASS= SMTP_SECURE=false
# RSS 入库：`POST /api/ingest/rss`，`Authorization: Bearer <INGEST_WEBHOOK_SECRET>`；示例脚本见 `scripts/curl-rss-ingest.example.sh`
INGEST_WEBHOOK_SECRET=replace-with-a-long-random-string
NORMALIZE_WEBHOOK_SECRET=replace-with-a-long-random-string
RAW_BLOB_LOCAL_DIR=.data/raw-blobs

# 站点对外绝对地址（canonical / OG / sitemap / robots）；本地开发可保持默认
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 部署环境：仅 production 默认允许索引；staging/dev/未设置 均默认 noindex
DEPLOYMENT_ENV=development

# 可选：强制覆盖索引策略（true/false）。留空表示按 DEPLOYMENT_ENV 自动判断
PUBLIC_INDEXING_OVERRIDE=

# 兼容旧开关（逐步废弃）：任一命中也会 noindex
ROBOTS_ALLOW_ALL=true
DISABLE_PUBLIC_INDEXING=

# 法务/纠错/侵权联系邮箱（公开页 footer /copyright 可读；不设则占位提示）
LEGAL_CONTACT_EMAIL=

# 站点所有权验证（可留空）；仅当 isPublicIndexingEnabled() 为 true 时才会输出 <meta> 标签
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
# 其它（Yandex / Baidu / 自定义 meta name）：分号或换行分隔，每行 metaName=value
OTHER_SITE_VERIFICATION=

# 公开写操作 in-memory 限流（单进程；重启清空）。本地压测可设 true 关闭限流，勿用于生产。
RATE_LIMIT_DISABLED=
# 可选：信任的反代 IP 头名（如 Cloudflare 填 cf-connecting-ip）；留空则用 x-forwarded-for / x-real-ip
RATE_LIMIT_TRUSTED_HEADER=
